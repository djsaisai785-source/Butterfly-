{
  "expo": {
    "name": "BUTTERFLY",
    "slug": "aura",
    "version": "1.0.0",
    "scheme": "butterfly",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A0A0F"
    },
    "android": {
      "package": "com.butterfly.night",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "bundleIdentifier": "com.butterfly.night",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "apiUrl": "https://butterfly-snjg.onrender.com",
      "router": {},
      "eas": {
        "projectId": "c0b46e62-feff-4a19-acb0-ceb4f7660712"
      }
    },
    "owner": "aurabutterflys-team"
  }
}
